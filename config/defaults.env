# cursorvmqemuglobal — system-wide defaults (installed to /etc/cursorvmqemu/defaults.env)
# User overrides: ~/.config/cursorvmqemu/config.env

# Storage pool (auto-detected on first run if empty)
DEFAULT_POOL="default"

# Colon-separated ISO search directories (~ expanded at runtime)
ISO_SEARCH_DIRS="~/Downloads:~/ISOs"

# Last used ISO path (set by create-vm wizard)
LAST_ISO_PATH=""

# Viewer preference: virt-manager | virt-viewer | ask
PREFER_VIEWER="ask"

# Default VM resources (wizard defaults)
DEFAULT_MEMORY_MB="8192"
DEFAULT_VCPUS="4"
DEFAULT_DISK_GB="40"
DEFAULT_DISK_GB_WINDOWS="60"
